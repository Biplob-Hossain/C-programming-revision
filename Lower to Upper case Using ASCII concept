#include<stdio.h>

int main()
{
    char ch;
    printf("Enter a lowercase character: ");
    scanf("%c", &ch);

    if (ch >= 'a' && ch <= 'z') 
    {

        ch = ch - 32; 
        printf("After conversion, character is: %c\n", ch);
    }
    else 
    {
        printf("This is not a lowercase character!\n");
    }

    return 0;
}
